{
  "name": "word-ai-assistant",
  "version": "1.0.0",
  "description": "Word AI Assistant - 基于DeepSeek的智能Word文档助手",
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --mode development",
    "start:desktop": "office-addin-debugging start manifest.xml desktop",
    "start:dev": "webpack serve --mode development",
    "sideload": "office-addin-dev-settings sideload manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "build": "webpack --mode production",
    "build:prod": "cross-env NODE_ENV=production webpack --mode production",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "keywords": [
    "office-add-in",
    "word",
    "ai",
    "deepseek"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@azure/msal-browser": "^3.30.0",
    "@azure/msal-common": "^16.0.3",
    "@azure/msal-react": "^2.2.0",
    "@fluentui/react": "^8.110.0",
    "@fluentui/react-components": "^9.40.0",
    "axios": "^1.6.0",
    "juice": "^11.1.0",
    "mammoth": "^1.6.0",
    "pdfjs-dist": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "scheduler": "^0.27.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "@babel/preset-typescript": "^7.23.0",
    "@types/node": "^25.0.3",
    "@types/office-js": "^1.0.350",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "buffer": "^6.0.3",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "dotenv": "^17.2.3",
    "html-webpack-plugin": "^5.5.3",
    "office-addin-debugging": "^5.0.0",
    "office-addin-dev-certs": "^1.11.0",
    "office-addin-dev-settings": "^3.0.6",
    "office-addin-manifest": "^1.12.0",
    "path-browserify": "^1.0.1",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.0",
    "typescript": "^5.2.2",
    "util": "^0.12.5",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
